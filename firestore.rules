rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function admin() { return signedIn() && request.auth.token.role == 'admin'; }
    function vendor() { return signedIn() && (request.auth.token.role == 'vendor' || admin()); }
    match /products/{id} { allow read: if resource.data.status == 'active' || admin() || (vendor() && resource.data.vendorId == request.auth.uid); allow write: if false; }
    match /categories/{id} { allow read: if true; allow write: if false; }
    match /vendors/{id} { allow read: if resource.data.status == 'active' || admin() || request.auth.uid == id; allow write: if false; }
    match /orders/{id} { allow read: if admin() || (signedIn() && resource.data.customerId == request.auth.uid); allow write: if false; }
    match /customers/{id} { allow read: if admin() || request.auth.uid == id; allow write: if false; }
    match /reviews/{id} { allow read: if resource.data.status == 'approved' || admin(); allow write: if false; }
    match /{document=**} { allow read, write: if false; }
  }
}
